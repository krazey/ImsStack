{
    // For presubmit test group.
    "presubmit": [
        {
            "name": "ImsStackJavaTests",
            "options": [
                {
                    "exclude-annotation": "androidx.test.filters.LargeTest"
                },
                {
                    "exclude-annotation": "androidx.test.filters.FlakyTest"
                }
            ]
        },
        {
            "name": "ImsStackNativeTests"
        }
    ],

    // For postsubmit test group.
    "postsubmit": [
        {
            "name": "ImsStackJavaTests"
        },
        {
            "name": "ImsStackNativeTests"
        }
    ],

    // ImsStack all unit tests.
    "ImsStack-all": [
        {
            "name": "ImsStackJavaTests"
        },
        {
            "name": "ImsStackNativeTests"
        }
    ],

    // ImsStack java unit tests.
    "ImsStack-java": [
        {
            "name": "ImsStackJavaTests"
        }
    ],

    // ImsStack java unit tests excluding "LargeTest" annotation.
    "ImsStack-java-exclude-largetest": [
        {
            "name": "ImsStackJavaTests",
            "options": [
                {
                    "exclude-annotation": "androidx.test.filters.LargeTest"
                }
            ]
        }
    ],

    // ImsStack native unit tests.
    "ImsStack-native": [
        {
            "name": "ImsStackNativeTests"
        }
    ],

    // ImsStack native unit tests for MmTel feature.
    "ImsStack-native-mmtel": [
        {
            "name": "ImsStackNativeConfigTests"
        },
        {
            "name": "ImsStackNativeEnablerTests"
        },
        {
            "name": "ImsStackNativeEngineTests"
        },
        {
            "name": "ImsStackNativeJniTests"
        },
        {
            "name": "ImsStackNativeMainTests"
        },
        {
            "name": "ImsStackNativePlatformTests"
        },
        {
            "name": "ImsStackNativeProtocolTests"
        },

        // protocol
        {
            "name": "ImsStackNativeProtocolSdpTests"
        },
        {
            "name": "ImsStackNativeProtocolSipTests"
        },

        // enabler
        {
            "name": "ImsStackNativeEnablerAosTests"
        },
        {
            "name": "ImsStackNativeEnablerMediaTests"
        },
        {
            "name": "ImsStackNativeEnablerMtcTests"
        },
        {
            "name": "ImsStackNativeEnablerMtsTests"
        }
    ],

    // For tiss-presubmit test group
    "tiss-presubmit": [
        {
            "name": "ImsStackTest",
            "options": [
                {
                    "include-filter": "com.android.imsstack.its.tests.ImsTissTest"
                }
            ]
        }
    ]
}
