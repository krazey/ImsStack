package {
    default_applicable_licenses: ["Android-Apache-2.0"],
}

java_defaults {
    name: "ims_stack_test_defaults",
    certificate: "platform",
    platform_apis: true,

    srcs: [
        "src/**/*.java",
    ],
    resource_dirs: [
        "res",
    ],
    javacflags: [
        "-Xlint",
    ],
    static_libs: [
        "androidx.test.core",
        "androidx.test.rules",
        "frameworks-base-testutils",
        "imsstack",
        "junit",
        "mockito-target",
        "platform-test-annotations",
        "testables",
        "truth",
        "scm_proto",
    ],
    libs: [
        "android.test.base.stubs.system",
        "android.test.mock.stubs.system",
        "android.test.runner.stubs.system",
    ],
    jni_libs: [
        "libimsstack",
    ],
    test_suites: ["general-tests"],
}

java_library {
    name: "scm_proto",
    proto: {
        type: "lite",
        canonical_path_from_root: false,
    },
    srcs: [
        "proto/scm.proto",
    ],
}

android_test {
    name: "ImsStackTest",
    defaults: ["ims_stack_test_defaults"],
    manifest: "AndroidManifest.xml",
    test_config: "AndroidTest.xml",
}

android_test {
    name: "ImsStackPresubmitTest",
    defaults: ["ims_stack_test_defaults"],
    manifest: "AndroidManifestPresubmitTest.xml",
    test_config: "AndroidPresubmitTest.xml",
}
