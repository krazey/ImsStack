package {
    default_applicable_licenses: ["Android-Apache-2.0"],
}

android_test {
    name: "ImsStackTest",
    certificate: "platform",
    platform_apis: true,
    manifest: "AndroidManifest.xml",

    srcs: [
        "src/**/*.java",
    ],
    resource_dirs: [
        "res",
    ],
    javacflags: [
        "-Xlint",
    ],
    static_libs: [
        "androidx.test.core",
        "androidx.test.rules",
        "frameworks-base-testutils",
        "imsstack",
        "junit",
        "mockito-target",
        "platform-test-annotations",
        "testables",
        "truth",
    ],
    libs: [
        "android.test.base",
        "android.test.mock",
        "android.test.runner",
    ],
    test_suites: ["general-tests"],
}
