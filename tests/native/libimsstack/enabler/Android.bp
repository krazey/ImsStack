package {
    default_team: "trendy_team_pmw_telephony",
    default_applicable_licenses: ["Android-Apache-2.0"],
}

cc_library_headers {
    name: "libimsstack_test_enabler_headers",
    export_include_dirs: [
        "interface",
        "interface/aos",
        "interface/mtc",
        "interface/mts",
        "interface/uce",
        "interface/sipcontroller",
    ],
}

cc_library_headers {
    name: "libimsstack_test_enabler_include_headers",
    export_include_dirs: [
        "include/aos",
        "include/media",
        "include/mtc",
        "include/mts",
    ],
}

cc_defaults {
    name: "imsstack_native_test_enabler_defaults",
    defaults: [
        "imsstack_native_test_defaults",
    ],
    header_libs: [
        "libimsstack_config_headers",
        "libimsstack_enabler_headers",
        "libimsstack_engine_headers",
        "libimsstack_platform_headers",
        "libimsstack_protocol_headers",
        "libpixelimsmedia_config_headers",
        "libimsstack_test_config_headers",
        "libimsstack_test_enabler_headers",
        "libimsstack_test_engine_headers",
        "libimsstack_test_platform_headers",
        "libimsstack_test_protocol_headers",
    ],
    static_libs: [
        "libimsstack-config",
        "libimsstack-enabler",
        "libimsstack-engine",
        "libimsstack-jni",
        "libimsstack-platform",
        "libimsstack-protocol",
        "libimsstack-test-engine",
        "libpixelimsmedia_config",
    ],
}

cc_test {
    name: "ImsStackNativeEnablerTests",
    defaults: [
        "imsstack_native_test_enabler_defaults",
    ],
    srcs: [
        "**/*.cpp",
    ],
    local_include_dirs: [
        "include/aos",
        "include/mtc",
        "include/mts",
        "include/media",
    ],
    test_config: "ImsStackNativeEnablerTests.xml",
}
