package {
    default_applicable_licenses: ["Android-Apache-2.0"],
}

cc_defaults {
    name: "imsstack_native_test_defaults",
    defaults: [
        "imsstack_native_defaults",
        "imsstack_shared_libs_defaults",
        "imsstack_tls_libs_defaults",
    ],
    test_suites: [
        "general-tests",
        "device-tests",
    ],
    static_libs: [
        "libgmock",
        "libgtest_main",
        "liblog",
    ],
}

cc_test {
    name: "ImsStackNativeTests",
    defaults: [
        "imsstack_native_test_defaults",
    ],
    srcs: [
        "**/*.cpp",
    ],
    local_include_dirs: [
        "enabler/include/aos",
        "enabler/include/mtc",
        "enabler/include/mts",
        "enabler/include/media",
        "enabler/interface",
        "enabler/interface/aos",
        "enabler/interface/mtc",
        "enabler/interface/mts",
        "enabler/interface/uce",
    ],
    header_libs: [
        "libimsstack_config_headers",
        "libimsstack_enabler_headers",
        "libimsstack_enabler_loader_headers",
        "libimsstack_engine_headers",
        "libimsstack_main_headers",
        "libimsstack_platform_headers",
        "libimsstack_platform_os_android_system-intf_headers",
        "libimsstack_protocol_headers",
        "libpixelimsmedia_config_headers",
    ] + [
        "libimsstack_test_config_headers",
        "libimsstack_test_enabler_headers",
        "libimsstack_test_engine_headers",
        "libimsstack_test_platform_headers",
        "libimsstack_test_protocol_headers",
    ],
    static_libs: [
        "libimsstack-config",
        "libimsstack-enabler",
        "libimsstack-engine",
        "libimsstack-jni",
        "libimsstack-main",
        "libimsstack-platform",
        "libimsstack-protocol",
        "libpixelimsmedia_config",
    ],

    test_config: "ImsStackNativeTests.xml",
}
