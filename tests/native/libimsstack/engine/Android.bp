package {
    default_team: "trendy_team_pmw_telephony",
    default_applicable_licenses: ["Android-Apache-2.0"],
}

// Do not add additional include paths with three depths.
cc_library_headers {
    name: "libimsstack_test_engine_headers",
    export_include_dirs: [
        "include/core",
        "include/registration",
        "include/service",
        "interface",
        "interface/core",
        "interface/registration",
        "interface/service",
        "interface/sipcore",
    ],
}

cc_defaults {
    name: "imsstack_native_test_engine_defaults",
    defaults: [
        "imsstack_native_test_defaults",
    ],
    header_libs: [
        "libimsstack_config_headers",
        "libimsstack_engine_headers",
        "libimsstack_platform_headers",
        "libimsstack_protocol_headers",
        "libimsstack_test_config_headers",
        "libimsstack_test_platform_headers",
    ],
    static_libs: [
        "libimsstack-config",
        "libimsstack-engine",
        "libimsstack-platform",
        "libimsstack-protocol",
    ],
}

cc_library_static {
    name: "libimsstack-test-engine",
    defaults: [
        "imsstack_native_test_engine_defaults",
    ],
    srcs: [
        "TestConnector.cpp",
        "TestEngine.cpp",
        "registration/TestRegistrationContext.cpp",
        "service/TestServiceContext.cpp",
        "sipcore/TestSipProtocol.cpp",
    ],
    local_include_dirs: [
        "include/core",
        "include/registration",
        "include/service",
        "include/sipcore",
        "interface",
        "interface/core",
        "interface/registration",
        "interface/service",
        "interface/sipcore",
    ],
}

cc_test {
    name: "ImsStackNativeEngineTests",
    defaults: [
        "imsstack_native_test_engine_defaults",
    ],
    srcs: [
        "**/*.cpp",
    ],
    local_include_dirs: [
        "include",
        "include/core",
        "include/registration",
        "include/service",
        "interface",
        "interface/core",
        "interface/registration",
        "interface/service",
        "interface/sipcore",
    ],
    static_libs: [
        "libimsstack-test-config",
    ],

    test_config: "ImsStackNativeEngineTests.xml",
}
