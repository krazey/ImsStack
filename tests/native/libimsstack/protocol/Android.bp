package {
    default_team: "trendy_team_pmw_telephony",
    default_applicable_licenses: ["Android-Apache-2.0"],
}

cc_library_headers {
    name: "libimsstack_test_protocol_headers",
    export_include_dirs: [
        "interface/xml",
    ],
}

cc_defaults {
    name: "imsstack_native_test_protocol_defaults",
    defaults: [
        "imsstack_native_test_defaults",
    ],
    header_libs: [
        "libimsstack_platform_headers",
        "libimsstack_protocol_headers",
    ],
    static_libs: [
        "libimsstack-platform",
        "libimsstack-protocol",
    ],
}

cc_test {
    name: "ImsStackNativeProtocolTests",
    defaults: [
        "imsstack_native_test_protocol_defaults",
    ],
    srcs: [
        "**/*.cpp",
    ],

    test_config: "ImsStackNativeProtocolTests.xml",
}
