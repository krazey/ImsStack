        </PreferenceCategory>
        <PreferenceCategory android:title="CarrierConfig: string-array"
            android:key="category_config_string_array">
            <ListPreference android:title="Item"
                android:entryValues="@array/carrier_config_items"
                android:entries="@array/carrier_config_items"
                android:key="config_string_array_items"
                android:defaultValue=""
