                android:selectable="true">
            </ListPreference>
            <EditTextPreference android:title="Value"
                android:key="config_string_value"
                android:dialogMessage="">
            </EditTextPreference>
        </PreferenceCategory>
        <PreferenceCategory android:title="CarrierConfig: int-array"
            android:key="category_config_int_array">
            <ListPreference android:title="Item"
                android:entryValues="@array/carrier_config_items"
                android:entries="@array/carrier_config_items"
                android:key="config_int_array_items"
                android:defaultValue=""
                android:enabled="true"
                android:selectable="true">
            </ListPreference>
            <EditTextPreference android:title="Value"
                android:key="config_int_array_value"
                android:dialogMessage="">
