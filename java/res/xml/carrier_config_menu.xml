            </ListPreference>
            <EditTextPreference android:title="Value"
                android:key="config_string_array_value"
                android:dialogMessage="">
            </EditTextPreference>
        </PreferenceCategory>
        <PreferenceCategory android:title="CarrierConfig: bundle"
            android:key="category_config_bundle">
            <ListPreference android:title="Bundle"
                android:entryValues="@array/carrier_config_items"
                android:entries="@array/carrier_config_items"
                android:key="config_bundle_keys"
                android:defaultValue=""
                android:enabled="true"
                android:selectable="true">
            </ListPreference>
            <ListPreference android:title="Item"
                android:entryValues="@array/carrier_config_items"
                android:entries="@array/carrier_config_items"
                android:key="config_bundle_items"
                android:defaultValue=""
                android:enabled="true"
                android:selectable="true">
            </ListPreference>
            <EditTextPreference android:title="Value"
                android:key="config_bundle_value"
                android:dialogMessage="">
            </EditTextPreference>
        </PreferenceCategory>
    </PreferenceScreen>
