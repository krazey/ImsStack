<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    android:key="carrier_config_editor"
    android:title="CarrierConfig Editor">
    <PreferenceScreen/> <!-- Empty row for notification bar. -->
    <PreferenceScreen/> <!-- Empty row for title bar. -->
    <PreferenceScreen android:title="CarrierConfig - Public"
        android:key="screen_carrier_config">
        <PreferenceScreen/> <!-- Empty for first row. -->
        <PreferenceCategory android:title="CarrierConfig: boolean"
            android:key="category_config_boolean">
            <ListPreference android:title="Item"
                android:entryValues="@array/carrier_config_items"
                android:entries="@array/carrier_config_items"
                android:key="config_boolean_items"
                android:defaultValue=""
                android:enabled="true"
                android:selectable="true">
            </ListPreference>
            <EditTextPreference android:title="Value"
                android:key="config_boolean_value"
                android:dialogMessage="">
            </EditTextPreference>
        </PreferenceCategory>
        <PreferenceCategory android:title="CarrierConfig: int"
            android:key="category_config_int">
            <ListPreference android:title="Item"
                android:entryValues="@array/carrier_config_items"
                android:entries="@array/carrier_config_items"
                android:key="config_int_items"
                android:defaultValue=""
                android:enabled="true"
                android:selectable="true">
            </ListPreference>
            <EditTextPreference android:title="Value"
                android:key="config_int_value"
                android:dialogMessage="">
            </EditTextPreference>
        </PreferenceCategory>
        <PreferenceCategory android:title="CarrierConfig: string"
            android:key="category_config_string">
            <ListPreference android:title="Item"
                android:entryValues="@array/carrier_config_items"
                android:entries="@array/carrier_config_items"
                android:key="config_string_items"
                android:defaultValue=""
