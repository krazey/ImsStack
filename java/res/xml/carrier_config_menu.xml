    <PreferenceScreen android:title="Dump Config" android:key="dump_config">
    </PreferenceScreen>
    <ListPreference android:title="Clear Test Config"
        android:entryValues="@array/two_state_value" android:entries="@array/two_state_entry"
        android:key="clear_test_config" android:defaultValue="no" android:enabled="true"
        android:selectable="true">
    </ListPreference>
    <ListPreference android:title="Test Carrier Id"
        android:entryValues="@array/carrier_config_carrier_id_value"
        android:entries="@array/carrier_config_carrier_id_entry"
        android:key="test_carrier_id" android:defaultValue="0" android:enabled="true"
        android:selectable="true">
    </ListPreference>
    <ListPreference android:title="VoLte Provisioning"
        android:entryValues="@array/volte_provisioning_value"
        android:entries="@array/volte_provisioning_entry"
        android:key="volte_provisioning" android:defaultValue="-1" android:enabled="true"
        android:selectable="true">
    </ListPreference>
